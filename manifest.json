{
  "manifest_version": 3,
  "name": "Tab Tidy – Smart Tab Grouper",
  "short_name": "Tab Tidy",
  "version": "1.1.0",
  "description": "One click to group all your tabs by category — Work, AI, Social, Entertainment and more. Fully customizable. 100% private.",
  "permissions": ["tabs", "tabGroups", "storage", "windows"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Tidy",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options.html"
}
